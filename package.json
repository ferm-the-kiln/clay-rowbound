{
  "name": "rowbound",
  "version": "1.7.3",
  "description": "Open-source CLI and MCP server for Google Sheets enrichment — waterfalls, conditions, HTTP API integrations",
  "type": "module",
  "bin": {
    "rowbound": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format src/",
    "format:fix": "biome format --write src/",
    "prepublishOnly": "npm run lint && npm run test && npm run build",
    "push": "bash scripts/push-appscript.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@supabase/supabase-js": "^2.103.0",
    "@types/node": "^22.13.10",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "jsonpath-plus": "^10.3.0",
    "picocolors": "^1.1.1",
    "typescript": "^5.7.3",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "tsx": "^4.19.3",
    "vitest": "^3.0.9"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eliasstravik/rowbound.git"
  },
  "homepage": "https://github.com/eliasstravik/rowbound",
  "bugs": "https://github.com/eliasstravik/rowbound/issues",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "overrides": {
    "path-to-regexp": "^8.4.0"
  },
  "keywords": [
    "google-sheets",
    "enrichment",
    "pipeline",
    "cli",
    "mcp",
    "waterfall",
    "rowbound"
  ]
}
