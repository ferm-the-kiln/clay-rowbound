# Rowbound - Configuration
# Copy this file to .env and fill in your values

# --- Rowbound Settings ---
# Webhook bearer token for authenticating incoming webhook requests
ROWBOUND_WEBHOOK_TOKEN=
# Set to "true" to allow non-HTTPS URLs (for local development only)
ROWBOUND_ALLOW_HTTP=

# --- API Keys (examples — use any keys your pipeline steps need) ---
CLEARBIT_API_KEY=your_clearbit_api_key_here
APOLLO_API_KEY=your_apollo_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here
